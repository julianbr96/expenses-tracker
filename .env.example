# Default local Postgres connection (replace with Neon in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expenses_tracker?schema=public"
# Default direct connection for Prisma schema operations
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/expenses_tracker?schema=public"

# Optional external provider for ARS/USD rate sync
DOLARITO_API_URL="https://api.dolarito.ar/v1/dolar-oficial"
DOLARITO_API_KEY=""
APP_PASSWORD=""

# Runtime defaults used by projection logic
DEFAULT_ARS_PER_USD="1100"
PROJECTION_MONTHS_AHEAD="24"
EXCHANGE_RATE_HISTORY_LIMIT="90"
EXPECTATION_REPEAT_MONTHS_DEFAULT="1"

# Expectation API behavior:
# true => re-submitting the same card+start month replaces that repeated series (shrinks/removes overflow months)
EXPECTATION_REPLACE_EXISTING_SERIES_DEFAULT="true"
