generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Currency {
  USD
  ARS
}

enum ExpenseSourceType {
  CREDIT_CARD
  DEBIT_CARD
  BANK_ACCOUNT
  PREPAID
  CASH
  OTHER
}

model Card {
  id           String              @id @default(cuid())
  name         String
  currency     Currency            @default(USD)
  sourceType   ExpenseSourceType   @default(CREDIT_CARD)
  userId       String?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  expenses     Expense[]
  expectations SpendingExpectation[]

  @@index([userId, createdAt])
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Decimal  @db.Decimal(14, 2)
  currency    Currency
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@index([date])
  @@index([cardId, date])
}

model IncomeSource {
  id         String   @id @default(cuid())
  name       String
  amount     Decimal  @db.Decimal(14, 2)
  currency   Currency
  startMonth String
  endMonth   String?
  userId     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([startMonth])
  @@index([userId, startMonth])
}

model FixedExpense {
  id         String   @id @default(cuid())
  name       String
  amount     Decimal  @db.Decimal(14, 2)
  currency   Currency
  startMonth String
  endMonth   String?
  userId     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([startMonth])
  @@index([userId, startMonth])
}

model SpendingExpectation {
  id        String   @id @default(cuid())
  month     String
  amount    Decimal  @db.Decimal(14, 2)
  currency  Currency
  seriesKey String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Restrict)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([cardId, month])
  @@index([cardId, seriesKey, month])
  @@index([month])
  @@index([userId, month])
}

model ExchangeRate {
  date      DateTime @id
  arsPerUsd Decimal  @db.Decimal(14, 6)
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyAdjustment {
  id        String   @id @default(cuid())
  month     String
  amount    Decimal  @db.Decimal(14, 2)
  currency  Currency @default(USD)
  note      String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([userId, month])
  @@unique([userId, month])
}

model Advancement {
  id        String   @id @default(cuid())
  month     String
  amount    Decimal  @db.Decimal(14, 2)
  currency  Currency @default(USD)
  note      String?
  userId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([userId, month])
}

model User {
  id            String             @id @default(cuid())
  username      String             @unique
  passwordHash  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  cards         Card[]
  incomes       IncomeSource[]
  fixedExpenses FixedExpense[]
  expectations  SpendingExpectation[]
  adjustments   MonthlyAdjustment[]
  advancements  Advancement[]
  refreshTokens AuthRefreshToken[]
}

model AuthRefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TelegramSession {
  chatId              BigInt   @id
  step                String   @default("IDLE")
  pendingCardId       String?
  pendingAmount       Decimal? @db.Decimal(14, 2)
  pendingCurrency     Currency?
  pendingDate         DateTime?
  pendingDescription  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([updatedAt])
}
