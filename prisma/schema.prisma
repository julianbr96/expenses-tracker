generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Currency {
  USD
  ARS
}

model Card {
  id           String              @id @default(cuid())
  name         String
  currency     Currency            @default(USD)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  expenses     Expense[]
  expectations SpendingExpectation[]
}

model Expense {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Decimal  @db.Decimal(14, 2)
  currency    Currency
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@index([date])
  @@index([cardId, date])
}

model IncomeSource {
  id         String   @id @default(cuid())
  name       String
  amount     Decimal  @db.Decimal(14, 2)
  currency   Currency
  startMonth String
  endMonth   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startMonth])
}

model FixedExpense {
  id         String   @id @default(cuid())
  name       String
  amount     Decimal  @db.Decimal(14, 2)
  currency   Currency
  startMonth String
  endMonth   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([startMonth])
}

model SpendingExpectation {
  id        String   @id @default(cuid())
  month     String
  amount    Decimal  @db.Decimal(14, 2)
  currency  Currency
  seriesKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([cardId, month])
  @@index([cardId, seriesKey, month])
  @@index([month])
}

model ExchangeRate {
  date      DateTime @id
  arsPerUsd Decimal  @db.Decimal(14, 6)
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyAdjustment {
  id        String   @id @default(cuid())
  month     String   @unique
  amount    Decimal  @db.Decimal(14, 2)
  currency  Currency @default(USD)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([month])
}

model Advancement {
  id        String   @id @default(cuid())
  month     String
  amount    Decimal  @db.Decimal(14, 2)
  currency  Currency @default(USD)
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([month])
}

model TelegramSession {
  chatId              BigInt   @id
  step                String   @default("IDLE")
  pendingCardId       String?
  pendingAmount       Decimal? @db.Decimal(14, 2)
  pendingCurrency     Currency?
  pendingDate         DateTime?
  pendingDescription  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([updatedAt])
}
